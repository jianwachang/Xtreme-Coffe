    <!-- Legale GDPR personalizzato -->
    <string name="pp_controller_h">Data controller</string>
    <string name="pp_controller_b">The data controller is Dario Condello. For any request regarding your data you can write to unlimitedvisionltd@gmail.com.</string>
    <string name="pp_legal_h">Legal bases</string>
    <string name="pp_legal_b">We process data for: performance of the service you request (Art. 6(1)(b) GDPR), such as creating your profile and sending or receiving invites; your consent (Art. 6(1)(a)) for access to location, contacts and camera and for sending notifications, which you can withdraw at any time from your device settings; our legitimate interest (Art. 6(1)(f)) in ensuring the security and proper functioning of the app.</string>
    <string name="pp_transfer_h">Transfers outside the EU</string>
    <string name="pp_transfer_b">Some providers (e.g. Google) may process data outside the European Union. In such cases the transfer is based on appropriate safeguards under the GDPR, such as the Standard Contractual Clauses adopted by the European Commission.</string>
    <string name="pp_rights_h">Your rights</string>
    <string name="pp_rights_b">As a data subject you have the right to access your data and to obtain its rectification, erasure or restriction, to object to processing, to request its portability and to withdraw your consent at any time. To exercise these rights write to unlimitedvisionltd@gmail.com. You also have the right to lodge a complaint with a supervisory authority: in Italy, the Garante per la protezione dei dati personali (www.garanteprivacy.it).</string>
    <string name="pp_children_h">Children</string>
    <string name="pp_children_b">The app is not intended for children under 14. If you become aware that a child has provided us with data without the consent of the holder of parental responsibility, contact us and we will delete it.</string>
    <string name="terms_provider_h">Service provider</string>
    <string name="terms_provider_b">The Extreme Coffee service is provided by Dario Condello. Contact: unlimitedvisionltd@gmail.com.</string>
    <string name="terms_law_h">Governing law and jurisdiction</string>
    <string name="terms_law_b">These terms are governed by Italian law. If you are a consumer resident in the European Union, the mandatory protections of the law of your country of residence and the jurisdiction of the consumer\'s courts remain unaffected.</string>
