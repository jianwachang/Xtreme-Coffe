    <!-- Privacy (permissions) -->
    <string name="privacy_intro">Extreme Coffee only uses the data needed to help you meet friends for a coffee.</string>
    <string name="privacy_perms_h">Permissions used</string>
    <string name="privacy_perms_body">• Location: to show you on the map during an Extreme Coffee and find nearby cafés.\n• Contacts: to recognise which friends already have the app and invite them.\n• Camera: for your profile photo and the final selfie.\n• Notifications: to alert you when you get an invite.</string>
    <string name="privacy_perms_note">You can grant or revoke each permission anytime from the system settings.</string>
    <string name="privacy_open_settings">Open app settings</string>
    <string name="privacy_data_h">Your data</string>
    <string name="privacy_data_body">You can delete your profile and associated data anytime from Account → \"Delete account and data\".</string>
    <string name="privacy_data_more">For full details on what data we collect and why, read the Privacy Policy.</string>

    <!-- Terms &amp; Conditions -->
    <string name="terms_updated">Last updated: June 2026</string>
    <string name="terms_intro">By using Extreme Coffee you accept these terms. If you don\'t agree, please don\'t use the app.</string>
    <string name="terms_1_h">1. The service</string>
    <string name="terms_1_b">Extreme Coffee is an app that lets you invite friends to meet for a coffee within a short time window, showing participants\' location during the event.</string>
    <string name="terms_2_h">2. Proper use</string>
    <string name="terms_2_b">You agree to use the app lawfully and respectfully, not to harass other users and not to post offensive or misleading content. You are responsible for the activity carried out by your account.</string>
    <string name="terms_3_h">3. Account</string>
    <string name="terms_3_b">To use the app you provide a nickname and a phone number. You are responsible for the accuracy of the data entered and for keeping your device secure.</string>
    <string name="terms_4_h">4. Location and meetups</string>
    <string name="terms_4_b">Location sharing happens only during an active Extreme Coffee and with the people involved. Meetups are at your own responsibility: use common sense and caution.</string>
    <string name="terms_5_h">5. Limitation of liability</string>
    <string name="terms_5_b">The app is provided \"as is\". We don\'t guarantee it is error-free or always available and, within the limits of the law, we are not liable for damages arising from use of the service.</string>
    <string name="terms_6_h">6. Changes</string>
    <string name="terms_6_b">We may update these terms; changes will be indicated by the update date.</string>
    <string name="terms_note">Document customised for Dario Condello. It is an initial template: have it reviewed by a professional before publishing. It does not constitute legal advice.</string>

    <!-- Privacy Policy -->
    <string name="pp_updated">Last updated: June 2026</string>
    <string name="pp_intro">This policy describes how the Extreme Coffee app processes users\' personal data, including in the European Union, under Regulation (EU) 2016/679 (GDPR).</string>
    <string name="pp_collect_h">Data we collect</string>
    <string name="pp_collect_b">• Profile: nickname and phone number, optional profile photo.\n• Location: approximate/precise location only during an active Extreme Coffee.\n• Contacts: used on the device to recognise friends who have the app.\n• Technical data: device identifier and token for notifications.</string>
    <string name="pp_why_h">Why we use them</string>
    <string name="pp_why_b">To let you create a profile, send and receive invites, show participants on the map during an event and send you notifications.</string>
    <string name="pp_where_h">Where they are stored</string>
    <string name="pp_where_b">Data is processed through Google Firebase services (Cloud Firestore, Cloud Messaging and Cloud Functions). Some information stays saved only on your device.</string>
    <string name="pp_share_h">Sharing</string>
    <string name="pp_share_b">We don\'t sell your data. It is shared only with the users involved in the invites you send or accept, and with the technical providers needed to run the app.</string>
    <string name="pp_keep_h">Retention and deletion</string>
    <string name="pp_keep_b">We keep data for as long as necessary to provide the service. You can delete your profile and associated data anytime from Account → \"Delete account and data\"; upon deletion the data is removed.</string>
    <string name="pp_contact_h">Contact</string>
    <string name="pp_contact_b">For any privacy request you can contact the controller at unlimitedvisionltd@gmail.com.</string>
    <string name="pp_note">Document customised for Dario Condello. It is a template: for full legal compliance a review by a professional is recommended. It does not constitute legal advice.</string>

